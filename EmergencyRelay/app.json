        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergencyrelay.app"
    },
    "extra": {
      "API_BASE": "http://172.26.109.198:5000",
      "API_BASE_ANDROID": "http://10.0.2.2:5000",
      "API_BASE_WEB": "http://localhost:5000",
      "eas": {
        "projectId": "4ddc16ba-942e-428c-b922-1402e5314177"
      }
    },
    "web": {
      "favicon": "./assets/BoysAndGirlsClubLogoNotClear.png"
